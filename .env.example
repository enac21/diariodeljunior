# Supabase DB
DATABASE_URL=""

# Supabase S3
SUPABASE_ACCESS_KEY_ID="access-key-id"
SUPABASE_SECRET_ACCESS_KEY="secret-access-key"
SUPABASE_BUCKET="supabase-bucket-name"
SUPABASE_PROJECT_REF="project-ref"
SUPABASE_S3_ENDPOINT="s3-supabase-endpoint"


# API Authentication Token - Required for character creation API
# Generate a secure random string for production
API_AUTH_TOKEN="your-secure-token-here"

# Discord Bot
DISCORD_TOKEN="your-discord-bot-token"
GUILD_ID="your-discord-guild-id"
WEB_AUTH_TOKEN="same-as-API_AUTH_TOKEN-or-separate"
ALLOWED_CHANNEL_IDS="channel-id-1,channel-id-2,channel-id-3"

# Socket.io (public URL for frontend connection)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# Temp password to access blocked pages
PAGE_PASSWORD="password"

# Habbo
HABBO_BATCH_THRESHOLD=20 # Number of users that triggers large batch mode (delay between each request)
HABBO_DELAY_SMALL_BATCH_MS=2500 # Delay between each request for small batches (random between 0 and this value in ms)
HABBO_DELAY_LARGE_BATCH_MS=25000 # Delay between each request for large batches (used as base for random delay calculation)