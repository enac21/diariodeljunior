generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Character {
  id               String   @id @default(uuid()) @db.Uuid
  username         String   @unique
  seed             Int
  generatorVersion Int      @default(1)
  selectedParts    Json
  createdAt        DateTime @default(now())

  @@index([createdAt])
}
